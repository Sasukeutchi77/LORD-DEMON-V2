# ╔══════════════════════════════════════════════════════╗
# ║         LORD DEMON V2 — Configuration .env           ║
# ║                                                      ║
# ║  ⚠️  REMPLISSEZ CE FICHIER AVANT DE LANCER LE BOT   ║
# ║  SOURCE DE VÉRITÉ : ce fichier EST la configuration  ║
# ║  Le bot refuse de démarrer si OWNER_NUMBER manque    ║
# ╚══════════════════════════════════════════════════════╝

# ══════════════════════════════════════════════════════
# ── OWNER (OBLIGATOIRE) ───────────────────────────────
# ══════════════════════════════════════════════════════
# Votre numéro WhatsApp avec l'indicatif pays, sans + ni espaces
# Exemple : 22653718750 (Burkina Faso)
# C'est LE seul endroit où vous définissez le propriétaire du bot.
OWNER_NUMBER=22653718750

# Owners supplémentaires (optionnel, séparés par virgule)
# Laissez commenté si vous avez un seul owner
# OWNER_NUMBERS=22653718750

# LID WhatsApp de l'owner (optionnel, auto-détecté au démarrage)
# Si vous ne savez pas ce que c'est, laissez vide
OWNER_LID=

# ══════════════════════════════════════════════════════
# ── SUDO (assistants du bot) ─────────────────────────
# ══════════════════════════════════════════════════════
# Numéros qui ont les droits sudo MAIS PAS les droits owner
# L'owner n'a PAS besoin d'être ici (il est déjà owner)
# Laissez vide si vous n'avez pas de sudo pré-configuré
SUDO=

# ══════════════════════════════════════════════════════
# ── PARAMÈTRES DU BOT ────────────────────────────────
# ══════════════════════════════════════════════════════
BOT_NAME=𝐋𝐎𝐑𝐃 ✘ 𝐃𝐄𝐌𝐎𝐍
PREFIX=.
MODE=public

# ══════════════════════════════════════════════════════
# ── MODÉRATION ───────────────────────────────────────
# ══════════════════════════════════════════════════════
MAX_WARNS=3
COOLDOWN_MS=2000
FLOOD_MAX=5
FLOOD_WINDOW=5000

# ══════════════════════════════════════════════════════
# ── APIs IA ──────────────────────────────────────────
# ══════════════════════════════════════════════════════
# Clé API Groq pour les commandes .ai et .demon
# Obtenez votre clé sur : https://console.groq.com
CLE_GROQ=YOUR_GROQ_API_KEY_HERE

# ══════════════════════════════════════════════════════
# ── APIs OPTIONNELLES ────────────────────────────────
# ══════════════════════════════════════════════════════
PIXABAY_KEY=
OPENWEATHER_KEY=
OCR_API_KEY=
DEEPGRAM_KEY=

# ══════════════════════════════════════════════════════
# ── COMPORTEMENT ─────────────────────────────────────
# ══════════════════════════════════════════════════════
AUTO_READ=true
AUTO_TYPING=true
SESSION_SECRET=change-moi-avec-un-long-secret-aleatoire
